{
  "name": "shifttracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:web": "next build",
    "start": "next start",
    "lint": "eslint",
    "cap:sync": "npx cap sync",
    "android:add": "npx cap add android",
    "android:sync": "npm run build:web && npx cap sync android",
    "android:open": "npx cap open android",
    "android:prepare": "npm run android:sync",
    "android:apk:mobile:debug": "npm run android:sync && cd android && gradlew.bat assembleMobileDebug",
    "android:apk:mobile:release": "npm run android:sync && cd android && gradlew.bat assembleMobileRelease",
    "android:apk:tv:debug": "npm run android:sync && cd android && gradlew.bat assembleTvDebug",
    "android:apk:tv:release": "npm run android:sync && cd android && gradlew.bat assembleTvRelease",
    "ios:add": "npx cap add ios",
    "ios:sync": "npm run build:web && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:prepare": "npm run ios:sync"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.10.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
